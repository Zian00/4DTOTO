# ── Database ─────────────────────────────────────────────────────────────────
# Local development (PostgreSQL running on your machine):
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PG_PASSWORD@localhost:5432/fourdtoto
# Docker Compose overrides this automatically — no change needed when using docker-compose up.

# ── Gemini OCR ────────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Scraper ───────────────────────────────────────────────────────────────────
# Delay between HTTP requests when bulk-seeding historical draws (seconds)
SCRAPE_DELAY_SECONDS=2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Use "*" for open access (dev only).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006

# ── Logging ───────────────────────────────────────────────────────────────────
# Set to true to log raw OCR ticket text (may contain sensitive data)
LOG_OCR_RAW_TEXT=false

# ── Image validation ──────────────────────────────────────────────────────────
ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp,image/heic,image/heif

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often (seconds) to poll Singapore Pools for pending ticket results
SCHEDULER_POLL_INTERVAL=1800
